<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BloomMarket</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#0b0b0b;
color:white;
}

header{
background:#161616;
padding:20px;
display:flex;
justify-content:space-between;
align-items:center;
position:sticky;
top:0;
}

.logo{
font-size:30px;
font-weight:bold;
color:#9b5cff;
}

nav a{
color:white;
margin-left:20px;
text-decoration:none;
}

.hero{
text-align:center;
padding:60px 20px;
background:linear-gradient(135deg,#1b0038,#4b0082);
}

.hero h1{
font-size:55px;
margin-bottom:15px;
}

.hero p{
font-size:20px;
opacity:.9;
}

.shop{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
gap:25px;
padding:40px;
}

.card{
background:#1a1a1a;
border-radius:20px;
padding:20px;
text-align:center;
transition:.3s;
}

.card:hover{
transform:translateY(-8px);
}

.card img{
width:140px;
height:140px;
object-fit:contain;
margin-bottom:15px;
}

.price{
font-size:28px;
color:#00ff99;
margin:15px 0;
}

.buy{
background:#9b5cff;
border:none;
padding:14px 25px;
border-radius:10px;
color:white;
font-size:18px;
cursor:pointer;
}

footer{
text-align:center;
padding:40px;
background:#161616;
margin-top:40px;
}

</style>
</head>

<body>

<header>

<div class="logo">
🦝 BloomMarket
</div>

<nav>

<a href="#">Home</a>

<a href="#">Shop</a>

<a href="#">Kontakt</a>

</nav>

</header>

<section class="hero">

<h1>Grow A Garden Shop</h1>

<p>Schnelle Lieferung • Sichere Zahlung • Faire Preise</p>

</section>

<section class="shop"><div class="card">
<img src="https://via.placeholder.com/200x200/ff00cc/ffffff?text=Rainbow+Seed">
<h2>Rainbow Seed</h2>
<div class="price">0,10 €</div>
<button class="buy" onclick="addToCart('Rainbow Seed',0.10)">In den Warenkorb</button>
</div>

<div class="card">
<img src="https://via.placeholder.com/200x200/d4af37/ffffff?text=Gold+Seed">
<h2>Gold Seed</h2>
<div class="price">0,05 €</div>
<button class="buy" onclick="addToCart('Gold Seed',0.05)">In den Warenkorb</button>
</div>

<div class="card">
<img src="https://via.placeholder.com/200x200/cccccc/000000?text=Unicorn">
<h2>Unicorn</h2>
<div class="price">0,75 €</div>
<button class="buy" onclick="addToCart('Unicorn',0.75)">In den Warenkorb</button>
</div>

<div class="card">
<img src="https://via.placeholder.com/200x200/ffaa00/000000?text=Dragonfly">
<h2>Dragon Fly</h2>
<div class="price">0,50 €</div>
<button class="buy" onclick="addToCart('Dragon Fly',0.50)">In den Warenkorb</button>
</div>

<div class="card">
<img src="https://via.placeholder.com/200x200/ff3300/ffffff?text=Dragon+Breath">
<h2>Dragon Breath</h2>
<div class="price">1,00 €</div>
<button class="buy" onclick="addToCart('Dragon Breath',1.00)">In den Warenkorb</button>
</div>

<div class="card">
<img src="https://via.placeholder.com/200x200/66ccff/000000?text=Moon+Bloom">
<h2>Moon Bloom</h2>
<div class="price">0,75 €</div>
<button class="buy" onclick="addToCart('Moon Bloom',0.75)">In den Warenkorb</button>
</div>

<div class="card">
<img src="https://via.placeholder.com/200x200/6600ff/ffffff?text=Hypno+Bloom">
<h2>Hypno Bloom</h2>
<div class="price">1,25 €</div>
<button class="buy" onclick="addToCart('Hypno Bloom',1.25)">In den Warenkorb</button>
</div>

<div class="card">
<img src="https://via.placeholder.com/200x200/9900ff/ffffff?text=Super+Sprinkler">
<h2>Super Sprinkler</h2>
<div class="price">0,30 €</div>
<button class="buy" onclick="addToCart('Super Sprinkler',0.30)">In den Warenkorb</button>
</div>

<div class="card">
<img src="https://via.placeholder.com/200x200/00ffff/000000?text=Super+Water+Can">
<h2>Super Water Can</h2>
<div class="price">0,10 €</div>
<button class="buy" onclick="addToCart('Super Water Can',0.10)">In den Warenkorb</button>
</div>

</section><script>
let cart = [];

function addToCart(name, price) {
    cart.push({name, price});
    document.getElementById("cart-count").innerText = cart.length;
    alert(name + " wurde zum Warenkorb hinzugefügt!");
}
</script>

</body>
</html>
